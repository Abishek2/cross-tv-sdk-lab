    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.12",
    "@types/supertest": "^6.0.2",
    "mocha": "^10.4.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
